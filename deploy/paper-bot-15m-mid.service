[Unit]
Description=Hyperliquid fade paper bot (15m, MID-only — Phase 2 A/B arm)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hyper
WorkingDirectory=/opt/hyperdata
ExecStart=/usr/bin/python3 /opt/hyperdata/paper_bot.py --interval 15m --datadir /opt/hyperdata/paper_15m_mid --tiers MID
Restart=always
RestartSec=15
StandardOutput=append:/opt/hyperdata/paper_15m_mid/service.out
StandardError=append:/opt/hyperdata/paper_15m_mid/service.err

[Install]
WantedBy=multi-user.target
